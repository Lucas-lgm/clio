{
  "name": "@clio/cli",
  "version": "0.1.0",
  "description": "Persistent memory for Claude Code",
  "type": "module",
  "bin": {
    "clio": "./dist/index.js"
  },
  "main": "./dist/server.js",
  "files": [
    "dist/",
    "bundled-models/"
  ],
  "scripts": {
